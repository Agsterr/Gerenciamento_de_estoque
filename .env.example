# =============================
# Database Configuration
# =============================
# Local (backend fora do Docker):
DB_URL=jdbc:postgresql://localhost:5432/gerenciamento_estoque
# Docker Compose sobrescreve para: jdbc:postgresql://postgres:5432/gerenciamento_estoque
DB_USER=postgres
DB_PASSWORD=postgres
DB_DRIVER=org.postgresql.Driver
FLYWAY_ENABLED=true

# =============================
# Server
# =============================
PORT=8082
# URL publica (webhook Asaas). Docker + cloudflared: use a URL do túnel ou seu dominio fixo
APP_PUBLIC_URL=http://localhost
HTTP_PORT=80

# Cloudflare Tunnel (servico cloudflared no docker-compose)
# Deixe vazio = túnel rápido trycloudflare.com (URL muda a cada restart; veja logs do container)
# Com token = URL fixa (Zero Trust > Networks > Tunnels > Configure > Install connector > Docker)
CLOUDFLARED_TUNNEL_TOKEN=

# =============================
# JWT
# =============================
JWT_SECRET=your_jwt_secret_min_256_bits

# =============================
# Payment Provider
# =============================
# asaas (padrão) ou mercadopago (legado)
APP_PAYMENT_PROVIDER=asaas

# =============================
# Asaas Configuration
# =============================
# sandbox = testes (sandbox.asaas.com) | production = produção real (www.asaas.com)
ASAAS_ENVIRONMENT=sandbox
# Sandbox: https://sandbox.asaas.com → Integrações → Chaves de API
# Docker local: docker/secrets/asaas_sandbox_api_key.txt
ASAAS_SANDBOX_API_KEY_FILE=/run/secrets/asaas_sandbox_api_key
ASAAS_SANDBOX_API_KEY=
# Produção: https://www.asaas.com → Integrações → Chaves de API ($aact_prod_...)
# Docker produção (recomendado): docker/secrets/asaas_prod_api_key.txt
ASAAS_PROD_API_KEY_FILE=/run/secrets/asaas_prod_api_key
ASAAS_PROD_API_KEY=$aact_your-production-api-key
# Token do webhook de PRODUÇÃO (painel www.asaas.com → Integrações → Webhooks)
ASAAS_WEBHOOK_TOKEN=your_webhook_auth_token_min_32_chars
# Redirecionamento após pagamento (successUrl). Só ative com domínio cadastrado no painel Asaas (Minha Conta → Informações).
ASAAS_PAYMENT_CALLBACK_ENABLED=false
APP_PUBLIC_URL=https://focodev.com.br

# =============================
# Mercado Pago Configuration (legado)
# =============================
# Use APP_PAYMENT_PROVIDER=mercadopago para reativar
MERCADOPAGO_ENVIRONMENT=test
MERCADOPAGO_PROD_ACCESS_TOKEN=APP_USR-your-production-access-token
MERCADOPAGO_PROD_PUBLIC_KEY=APP_USR-your-production-public-key
MERCADOPAGO_TEST_ACCESS_TOKEN=TEST-your-test-access-token
MERCADOPAGO_TEST_PUBLIC_KEY=TEST-your-test-public-key
MERCADOPAGO_TEST_PAYER_EMAIL=test_user_xxxx@testuser.com
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret
